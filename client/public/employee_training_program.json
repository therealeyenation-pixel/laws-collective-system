{
  "metadata": {
    "classification": "INTERNAL USE ONLY - HR DEPARTMENT",
    "lastUpdated": "2026-01-17",
    "approvedBy": "Shanna Russell, Founder/Matriarch/CEO",
    "version": "1.0",
    "managedBy": "HR Department in coordination with CETO (Cornelius)"
  },
  "overview": {
    "description": "Comprehensive new employee training program for The L.A.W.S. Collective and all subsidiary entities. This program ensures all team members receive consistent foundational training while also receiving role-specific preparation for their departments.",
    "philosophy": "We believe in investing in our people from day one. Training is not just about skills—it's about understanding our mission, values, and how each role contributes to building generational wealth for our community.",
    "objectives": [
      "Integrate new employees into organizational culture",
      "Provide foundational knowledge of all entities and their missions",
      "Develop role-specific competencies",
      "Establish clear expectations and success metrics",
      "Build relationships across the organization",
      "Prepare employees for long-term growth and potential contractor transition"
    ]
  },
  "trainingStructure": {
    "phases": [
      {
        "phase": 1,
        "name": "Pre-boarding",
        "timing": "1-2 weeks before start date",
        "description": "Preparation before first day",
        "responsible": "HR Department",
        "activities": [
          {
            "activity": "Welcome Package",
            "description": "Send digital welcome kit with organizational overview, team introductions, and first-day logistics",
            "deliverables": ["Welcome email", "Org chart", "First week schedule", "Required documents checklist"]
          },
          {
            "activity": "System Access Setup",
            "description": "Create accounts for email, platform, communication tools",
            "deliverables": ["Email account", "Platform login", "Microsoft Teams access", "Shared drive access"]
          },
          {
            "activity": "Equipment Coordination",
            "description": "Arrange for any required equipment or software",
            "deliverables": ["Equipment order/shipment", "Software licenses"]
          },
          {
            "activity": "Buddy Assignment",
            "description": "Assign an onboarding buddy from the department or organization",
            "deliverables": ["Buddy introduction email", "Buddy meeting scheduled"]
          }
        ]
      },
      {
        "phase": 2,
        "name": "Orientation Week",
        "timing": "Days 1-5",
        "description": "Foundation building and organizational introduction",
        "responsible": "HR Department + Department Lead",
        "activities": [
          {
            "day": 1,
            "name": "Welcome Day",
            "schedule": [
              {"time": "9:00 AM", "activity": "Welcome meeting with HR", "duration": "1 hour"},
              {"time": "10:00 AM", "activity": "Paperwork completion (I-9, W-4, benefits enrollment)", "duration": "1.5 hours"},
              {"time": "11:30 AM", "activity": "System access verification and tech setup", "duration": "1 hour"},
              {"time": "1:00 PM", "activity": "Lunch with buddy/team", "duration": "1 hour"},
              {"time": "2:00 PM", "activity": "Meet with direct supervisor - role overview", "duration": "1.5 hours"},
              {"time": "3:30 PM", "activity": "Platform tour and navigation training", "duration": "1 hour"}
            ]
          },
          {
            "day": 2,
            "name": "Organization Deep Dive",
            "schedule": [
              {"time": "9:00 AM", "activity": "L.A.W.S. Framework Training (Land, Air, Water, Self)", "duration": "2 hours"},
              {"time": "11:00 AM", "activity": "Entity Overview - All 4 entities and their missions", "duration": "1.5 hours"},
              {"time": "1:00 PM", "activity": "Trust Structure and Governance (overview only)", "duration": "1 hour"},
              {"time": "2:00 PM", "activity": "Token Economy and Ownership Model", "duration": "1.5 hours"},
              {"time": "3:30 PM", "activity": "Q&A with CETO or HR", "duration": "1 hour"}
            ]
          },
          {
            "day": 3,
            "name": "Policies and Compliance",
            "schedule": [
              {"time": "9:00 AM", "activity": "Employee Handbook Review", "duration": "2 hours"},
              {"time": "11:00 AM", "activity": "Code of Conduct and Ethics", "duration": "1 hour"},
              {"time": "1:00 PM", "activity": "Confidentiality and Data Security", "duration": "1 hour"},
              {"time": "2:00 PM", "activity": "Grant Compliance Basics (for applicable roles)", "duration": "1.5 hours"},
              {"time": "3:30 PM", "activity": "HR Policies Q&A", "duration": "1 hour"}
            ]
          },
          {
            "day": 4,
            "name": "Tools and Systems",
            "schedule": [
              {"time": "9:00 AM", "activity": "Communication Tools Training (Teams, Email)", "duration": "1.5 hours"},
              {"time": "10:30 AM", "activity": "Project Management Tools", "duration": "1.5 hours"},
              {"time": "1:00 PM", "activity": "Document Management and File Organization", "duration": "1 hour"},
              {"time": "2:00 PM", "activity": "Time Tracking and Reporting", "duration": "1 hour"},
              {"time": "3:00 PM", "activity": "Department-Specific Systems Introduction", "duration": "2 hours"}
            ]
          },
          {
            "day": 5,
            "name": "Team Integration",
            "schedule": [
              {"time": "9:00 AM", "activity": "Department team meeting", "duration": "1.5 hours"},
              {"time": "10:30 AM", "activity": "Cross-functional introductions", "duration": "1.5 hours"},
              {"time": "1:00 PM", "activity": "First assignment briefing", "duration": "1.5 hours"},
              {"time": "2:30 PM", "activity": "Week 1 check-in with supervisor", "duration": "1 hour"},
              {"time": "3:30 PM", "activity": "Goal setting for first 30 days", "duration": "1 hour"}
            ]
          }
        ]
      },
      {
        "phase": 3,
        "name": "Department Training",
        "timing": "Weeks 2-4",
        "description": "Role-specific skill development",
        "responsible": "Department Lead + CETO",
        "structure": "See departmentTraining section for specific tracks"
      },
      {
        "phase": 4,
        "name": "Integration Period",
        "timing": "Days 30-90",
        "description": "Full integration with ongoing support",
        "responsible": "Department Lead + HR",
        "milestones": [
          {
            "day": 30,
            "name": "30-Day Review",
            "activities": [
              "Performance check-in with supervisor",
              "Training progress assessment",
              "Goal adjustment if needed",
              "Feedback collection from new employee"
            ]
          },
          {
            "day": 60,
            "name": "60-Day Review",
            "activities": [
              "Skills assessment",
              "Project contribution review",
              "Additional training needs identification",
              "Team integration feedback"
            ]
          },
          {
            "day": 90,
            "name": "Probationary Review",
            "activities": [
              "Formal performance evaluation",
              "Confirmation of employment or extension of probation",
              "Long-term goal setting",
              "Career development discussion",
              "Transition to regular performance cycle"
            ]
          }
        ]
      }
    ]
  },
  "standardTraining": {
    "description": "Required training for ALL employees regardless of position or department",
    "modules": [
      {
        "id": "ST-001",
        "name": "Welcome to The L.A.W.S. Collective",
        "duration": "2 hours",
        "format": "Video + Interactive",
        "content": [
          "Founder's welcome message",
          "History and vision of the organization",
          "The L.A.W.S. framework explained",
          "How we're different: Building generational wealth"
        ],
        "assessment": "Quiz (80% to pass)",
        "deadline": "Day 2"
      },
      {
        "id": "ST-002",
        "name": "Understanding Our Entities",
        "duration": "1.5 hours",
        "format": "Interactive presentation",
        "content": [
          "The L.A.W.S. Collective, LLC - Holding company",
          "LAWS, LLC - Autonomous wealth platform",
          "Real-Eye-Nation LLC - Media and narrative",
          "LuvOnPurpose Outreach Temple and Academy Society - Education and community"
        ],
        "assessment": "Entity matching exercise",
        "deadline": "Day 3"
      },
      {
        "id": "ST-003",
        "name": "Token Economy and Ownership",
        "duration": "1 hour",
        "format": "Video + Q&A",
        "content": [
          "How token earnings work",
          "Ownership stake explained",
          "Performance metrics and rewards",
          "Path from W-2 to contractor"
        ],
        "assessment": "Comprehension check",
        "deadline": "Day 5"
      },
      {
        "id": "ST-004",
        "name": "Code of Conduct",
        "duration": "1 hour",
        "format": "Self-paced reading + acknowledgment",
        "content": [
          "Professional standards",
          "Ethical guidelines",
          "Conflict of interest policy",
          "Reporting concerns"
        ],
        "assessment": "Signed acknowledgment",
        "deadline": "Day 3"
      },
      {
        "id": "ST-005",
        "name": "Data Security and Confidentiality",
        "duration": "1 hour",
        "format": "Interactive module",
        "content": [
          "Handling sensitive information",
          "Password and access security",
          "Client/member confidentiality",
          "Data breach reporting"
        ],
        "assessment": "Scenario-based quiz",
        "deadline": "Day 5"
      },
      {
        "id": "ST-006",
        "name": "Communication and Collaboration Tools",
        "duration": "1.5 hours",
        "format": "Hands-on training",
        "content": [
          "Microsoft Teams basics",
          "Email etiquette and standards",
          "Document sharing and collaboration",
          "Meeting scheduling and etiquette"
        ],
        "assessment": "Practical demonstration",
        "deadline": "Day 4"
      },
      {
        "id": "ST-007",
        "name": "Workplace Harassment Prevention",
        "duration": "1 hour",
        "format": "Video + scenarios",
        "content": [
          "Recognizing harassment",
          "Reporting procedures",
          "Bystander intervention",
          "Creating respectful workplace"
        ],
        "assessment": "Scenario responses",
        "deadline": "Week 2"
      },
      {
        "id": "ST-008",
        "name": "Grant Compliance Fundamentals",
        "duration": "1 hour",
        "format": "Presentation",
        "content": [
          "Why grant compliance matters",
          "Basic documentation requirements",
          "Time tracking for grant-funded work",
          "Who to ask for help"
        ],
        "assessment": "Acknowledgment",
        "deadline": "Week 2",
        "applicableTo": "All employees (awareness level)"
      }
    ],
    "totalHours": 10,
    "completionDeadline": "End of Week 2"
  },
